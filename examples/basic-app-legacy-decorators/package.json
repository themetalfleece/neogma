{
  "name": "@neogma-examples/basic-app-legacy-decorators",
  "version": "1.0.0",
  "private": true,
  "description": "Runnable example app demonstrating every neogma feature against a local Neo4j instance.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node --enable-source-maps dist/index.js",
    "dev": "tsc && node --enable-source-maps dist/index.js",
    "clean": "rimraf dist",
    "lint": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,json}\""
  },
  "dependencies": {
    "neogma": "link:../../",
    "dotenv": "^17.2.3"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.3.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.2",
    "typescript": "^5.9.3"
  }
}
