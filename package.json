{
  "name": "neogma",
  "version": "1.16.1",
  "description": "Object-Graph-Mapping neo4j framework, Fully-typed with TypeScript, for easy and flexible node and relationship creation",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./legacy": {
      "types": "./dist/Decorators/legacy/index.d.ts",
      "default": "./dist/Decorators/legacy/index.js"
    },
    "./dist/*.js": "./dist/*.js",
    "./dist/*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "typesVersions": {
    "*": {
      "legacy": [
        "./dist/Decorators/legacy/index.d.ts"
      ]
    }
  },
  "sideEffects": [
    "./dist/Decorators/polyfill.js",
    "./dist/Decorators/index.js"
  ],
  "author": "Jason Athanasoglou <jathanasoglou@outlook.com>",
  "license": "MIT",
  "engines": {
    "node": ">=18.14.0"
  },
  "files": [
    "dist/**/*"
  ],
  "dependencies": {
    "clone": "^2.1.2",
    "neo4j-driver": "^6.0.1",
    "revalidator": "^0.3.1",
    "typebox": "^1.3.1"
  },
  "devDependencies": {
    "@types/clone": "^2.1.4",
    "@types/revalidator": "^0.3.12",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.3.0",
    "jest": "^30.2.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.2",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "lint": "eslint --fix --quiet \"src/**/*.ts\"",
    "format": "prettier --log-level silent --write \"src/**/*.ts\"",
    "clean": "rimraf -rf dist",
    "prepare": "pnpm clean && pnpm build",
    "prebuild": "pnpm lint && pnpm format",
    "build": "tsc -p tsconfig.build.json",
    "test": "jest",
    "docs:dev": "pnpm -C docs dev",
    "docs:build": "pnpm -C docs build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/themetalfleece/neogma.git"
  },
  "keywords": [
    "neo4j",
    "ogm",
    "graph",
    "databases",
    "cypher"
  ],
  "bugs": {
    "url": "https://github.com/themetalfleece/neogma/issues"
  },
  "homepage": "https://github.com/themetalfleece/neogma#readme",
  "packageManager": "pnpm@11.9.0"
}