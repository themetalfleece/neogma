{
  "name": "@neogma/nest",
  "version": "1.0.0",
  "description": "NestJS integration module for neogma - provides NeogmaModule with forRoot/forRootAsync, lifecycle management, and dependency injection.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "license": "MIT",
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "clean": "rimraf dist",
    "lint": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,json}\""
  },
  "peerDependencies": {
    "@nestjs/common": ">=10.0.0",
    "@nestjs/core": ">=10.0.0",
    "neogma": ">=2.0.0"
  },
  "devDependencies": {
    "@nestjs/common": "^11.1.28",
    "@nestjs/core": "^11.1.28",
    "@types/node": "^26.1.1",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-simple-import-sort": "^14.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "@types/jest": "^30.0.0",
    "jest": "^30.4.2",
    "neogma": "workspace:*",
    "ts-jest": "^29.4.11",
    "prettier": "^3.9.5",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^6.1.3",
    "rxjs": "^7.8.2",
    "typescript": "^6.0.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/themetalfleece/neogma.git",
    "directory": "packages/nest"
  },
  "keywords": [
    "neo4j",
    "neogma",
    "nestjs",
    "ogm",
    "graph",
    "module"
  ],
  "bugs": {
    "url": "https://github.com/themetalfleece/neogma/issues"
  },
  "homepage": "https://github.com/themetalfleece/neogma/tree/main/packages/nest#readme"
}